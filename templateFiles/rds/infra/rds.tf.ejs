resource "aws_db_parameter_group" "main" {
  family = "mysql8.0"

  <% Object.entries(parameters).forEach(([key, value]) => { -%>
    parameter {
      name  = "<%= key %>"
      value = "<%= value %>"
      apply_method = "pending-reboot"
    }
  <% }); -%>
}

resource "aws_db_instance" "main" {
  identifier          = "${var.name}-${var.environment}"
  snapshot_identifier = var.snapshot_id

  allocated_storage = var.snapshot_id != null ? null : var.storage
  db_name           = var.snapshot_id != null ? null : var.database_name
  username          = var.snapshot_id != null ? null : var.username
  password          = var.snapshot_id != null ? null : var.password
  engine            = var.snapshot_id != null ? null : "mysql"
  engine_version    = var.snapshot_id != null ? null : "8.0"

  instance_class          = var.instance_type
  availability_zone       = local.availability_zones[0]
  db_subnet_group_name    = aws_db_subnet_group.main.id
  vpc_security_group_ids  = [aws_security_group.rds.id]
  skip_final_snapshot     = true
  publicly_accessible     = true
  apply_immediately       = true
  backup_retention_period = 2
  backup_window           = "01:00-01:30"
  maintenance_window      = "Sun:05:00-Sun:05:30"
  parameter_group_name    = aws_db_parameter_group.main.name
}

resource "aws_db_subnet_group" "main" {
  name       = "${var.name}-${var.environment}"
  subnet_ids = values(aws_subnet.main)[*].id
}

resource "aws_security_group" "rds" {
  vpc_id = var.vpc_id

  ingress {
    protocol         = "tcp"
    from_port        = 3306
    to_port          = 3306
    cidr_blocks      = ["0.0.0.0/0"]
    ipv6_cidr_blocks = ["::/0"]
  }
}
